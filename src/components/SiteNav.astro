---
interface Props {
	currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const links = [
	{ href: '/', label: 'Home' },
	{ href: '/walks', label: 'Walks' },
	{ href: '/history', label: 'History' },
	{ href: '/bath', label: 'Bath' },
	{ href: '/eat-drink', label: 'Eat & Drink' },
	{ href: '/stay', label: 'Stay' }
];
---

<nav class="top-nav" aria-label="Main">
	<div class="nav-group">
		{links.map((link) => (
			<a href={link.href} class={currentPath === link.href ? 'active' : ''} data-link>{link.label}</a>
		))}
	</div>
</nav>

<style>
	.top-nav {
		max-width: 980px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		padding: 0.6rem 0.9rem;
		position: sticky;
		top: 0;
		z-index: 40;
		background: rgba(255, 251, 244, 0.78);
		border: 1px solid rgba(106, 81, 47, 0.18);
		border-radius: 14px;
		backdrop-filter: blur(10px) saturate(120%);
		box-shadow:
			0 10px 28px rgba(48, 37, 20, 0.08),
			0 1px 0 rgba(255, 255, 255, 0.55) inset;
	}

	.nav-group {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		align-items: center;
		justify-content: center;
	}

	.top-nav a[data-link] {
		text-decoration: none;
		color: #3c342a;
		padding: 0.2rem 0.05rem;
		font-size: 0.94rem;
		font-weight: 500;
		letter-spacing: 0.01em;
		border-bottom: 1px solid transparent;
		transition: color 0.2s ease, border-color 0.2s ease;
	}

	.top-nav a[data-link]:hover,
	.top-nav a[data-link].active {
		color: #243d2d;
		border-color: rgba(47, 75, 57, 0.6);
	}

	@media (max-width: 860px) {
		.top-nav {
			gap: 0.55rem;
			padding: 0.65rem 0.65rem 0.75rem;
			border-radius: 12px;
		}

		.nav-group {
			flex-wrap: wrap;
			justify-content: center;
			gap: 0.65rem 1rem;
		}

		.top-nav a[data-link] {
			font-size: 0.91rem;
		}
	}
</style>
