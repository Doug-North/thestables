---
interface Props {
	currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const links = [
	{ href: '/', label: 'Home' },
	{ href: '/walks', label: 'Walks' },
	{ href: '/history', label: 'History' },
	{ href: '/bath', label: 'Bath' },
	{ href: '/eat-drink', label: 'Eat & Drink' },
	{ href: '/stay', label: 'Stay' }
];
---

<div class="header-container">
	<a href="/" class="logo-link" title="The Stables Home">
		<img src="/boa-bridge.png" alt="The Stables Logo" class="nav-logo" />
	</a>
	<span class="town-name">Bradford-on-Avon</span>
	<nav class="top-nav" aria-label="Main">
		<div class="nav-group">
			{links.map((link) => (
				<a href={link.href} class={currentPath === link.href ? 'active' : ''} data-link>{link.label}</a>
			))}
		</div>
	</nav>
</div>

<style>
	.header-container {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.8rem;
		margin-bottom: 2.5rem;
		padding-top: 1rem;
	}

	.town-name {
		font-family: Baskerville, 'Goudy Old Style', 'Palatino', serif;
		font-size: 0.85rem;
		text-transform: uppercase;
		color: #2d2a26;
		letter-spacing: 0.35em;
		margin-bottom: 1.2rem;
		opacity: 0.85;
		font-weight: 400;
	}

	.top-nav {
		width: 100%;
		max-width: 980px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0.65rem 1rem;
		position: sticky;
		top: 1rem;
		z-index: 40;
		background: rgba(255, 251, 244, 0.82);
		border: 1px solid rgba(106, 81, 47, 0.15);
		border-radius: 16px;
		backdrop-filter: blur(12px) saturate(140%);
		box-shadow:
			0 12px 32px rgba(48, 37, 20, 0.1),
			0 1px 0 rgba(255, 255, 255, 0.6) inset;
	}

	.logo-link {
		display: block;
		transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
	}

	.logo-link:hover {
		transform: scale(1.03);
	}

	.nav-logo {
		display: block;
		height: 160px;
		width: auto;
		filter: drop-shadow(0 6px 12px rgba(0, 0, 0, 0.06));
	}

	.nav-group {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		align-items: center;
		justify-content: center;
	}

	.top-nav a[data-link] {
		text-decoration: none;
		color: #3c342a;
		padding: 0.2rem 0.05rem;
		font-size: 0.94rem;
		font-weight: 500;
		letter-spacing: 0.01em;
		border-bottom: 1px solid transparent;
		transition: color 0.2s ease, border-color 0.2s ease;
	}

	.top-nav a[data-link]:hover,
	.top-nav a[data-link].active {
		color: #243d2d;
		border-color: rgba(47, 75, 57, 0.6);
	}

	@media (max-width: 860px) {
		.top-nav {
			gap: 0.55rem;
			padding: 0.65rem 0.65rem 0.75rem;
			border-radius: 12px;
		}

		.nav-group {
			flex-wrap: wrap;
			justify-content: center;
			gap: 0.65rem 1rem;
		}

		.top-nav a[data-link] {
			font-size: 0.91rem;
		}
	}
</style>
