---

<Layout title="Eat & Drink in BOA | The Stables" description="Walking-time food and drink recommendations from The Stables in Bradford-on-Avon.">
	<div class="page">
		<SiteNav currentPath={Astro.url.pathname} />
		<main>
			<header class="hero">
				<p class="eyebrow">Local Food Guide</p>
				<h1>Eat and Drink</h1>
				<p>
					Walking times are from 14c St Margaret's Street. All places listed have decent options
					for dietary restrictions.
				</p>
				<div class="hero-meta">
					<p><span class="icon icon-route"></span>All walkable from the cottage</p>
					<p><span class="icon icon-clock"></span>Quick timings included</p>
					<p><span class="icon icon-map"></span>Mix of coffee, brunch, pubs, and dinner</p>
				</div>
			</header>

			<section class="food-grid" aria-label="BOA food and drink recommendations">
				{venues.map((venue) => (
					<article class="food-card">
						<div class="image-wrap">
							<img src={venue.image} alt={venue.imageAlt} loading="lazy" />
							{venue.isPlaceholder && (
								<div class="placeholder-note">
									Photo coming soon
								</div>
							)}
						</div>
						<div class="content">
							<h2>{venue.title}</h2>
							<p class="meta-row"><span class="icon icon-clock"></span><span class="duration">{venue.duration}</span></p>
							<p>{venue.summary}</p>
							<p class="credit">
								Photo:
								<a href={venue.attributionUrl} target="_blank" rel="noreferrer">{venue.attributionLabel}</a>
							</p>
						</div>
					</article>
				))}
			</section>
		</main>
	</div>
</Layout>

<style>
	.page {
		min-height: 100vh;
		padding: 2rem 1.25rem 3rem;
		background:
			radial-gradient(circle at 10% 0%, rgba(182, 132, 58, 0.16), transparent 36%),
			radial-gradient(circle at 100% 100%, rgba(42, 75, 57, 0.17), transparent 36%),
			#f5efe4;
	}

	main {
		max-width: 980px;
		margin: 0 auto;
	}

	.hero {
		padding-top: 0.7rem;
	}

	.eyebrow {
		margin: 0 0 0.4rem;
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #6e5d43;
	}

	h1 {
		font-family: 'Palatino Linotype', 'Book Antiqua', Palatino, serif;
		font-size: clamp(2rem, 4.8vw, 3.2rem);
		margin: 0;
	}

	.hero p {
		max-width: 68ch;
		margin: 0.7rem 0 0;
		color: #40362b;
	}

	.hero-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: 0.8rem;
	}

	.hero-meta p {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		margin: 0;
		font-size: 0.86rem;
		color: #5b4c39;
	}

	.food-grid {
		margin-top: 1.3rem;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1rem;
	}

	.food-card {
		background: rgba(255, 255, 255, 0.78);
		border: 1px solid rgba(96, 74, 43, 0.2);
		border-radius: 14px;
		overflow: hidden;
	}

	.food-card img {
		width: 100%;
		height: 170px;
		object-fit: cover;
		display: block;
	}

	.image-wrap {
		position: relative;
	}

	.placeholder-note {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 10px;
		background: rgba(24, 31, 28, 0.42);
		color: #f5efe4;
		font-size: 0.8rem;
		font-weight: 650;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		text-align: center;
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.45);
	}

	.content {
		padding: 0.9rem;
	}

	.content h2 {
		margin: 0;
		font-size: 1.15rem;
		font-family: 'Palatino Linotype', 'Book Antiqua', Palatino, serif;
	}

	.meta-row {
		display: inline-flex;
		align-items: center;
		gap: 0.42rem;
		margin: 0.55rem 0 0;
	}

	.duration {
		display: inline-block;
		padding: 0.18rem 0.5rem;
		border-radius: 999px;
		font-size: 0.78rem;
		font-weight: 600;
		background: #ebe0cc;
		color: #5b4728;
	}

	.icon {
		display: inline-block;
		width: 0.62rem;
		height: 0.62rem;
		border-radius: 999px;
		background: #78613f;
		flex: none;
	}

	.icon-clock {
		background: #5f7c67;
	}

	.icon-map {
		background: #7d5a78;
	}

	.content p {
		margin: 0.65rem 0 0;
		color: #3f3429;
	}

	.credit {
		font-size: 0.86rem;
	}

	.credit a {
		color: #2f4b39;
		text-decoration: none;
		font-weight: 600;
	}

	.credit a:hover {
		text-decoration: underline;
	}
</style>
