---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';

const historyStops = [
	{
		title: 'Saxon Church of St Laurence',
		duration: '7 mins',
		summary:
			'Early 11th-century church; one of the finest surviving pre-Conquest buildings in England.',
		image:
			'https://commons.wikimedia.org/wiki/Special:FilePath/Bradford%20on%20Avon%20St%20Laurence%27s%20Church%20a%20rare%20Saxon%20church.JPG',
		imageAlt: 'Saxon Church of St Laurence, Bradford-on-Avon',
		attributionLabel: 'Spudgun67 (CC BY-SA 4.0)',
		attributionUrl:
			'https://commons.wikimedia.org/wiki/File:Bradford_on_Avon_St_Laurence%27s_Church_a_rare_Saxon_church.JPG'
	},
	{
		title: 'St Mary’s Chapel (Tory Hill)',
		duration: '15 mins uphill',
		summary:
			'First recorded in 1533; the best view over Bradford-on-Avon.',
		image:
			'https://commons.wikimedia.org/wiki/Special:FilePath/Chapel%20of%20St%20Mary%20Tory.jpg',
		imageAlt: 'Chapel of St Mary Tory on Tory Hill',
		attributionLabel: 'Wilts24 (CC BY-SA 4.0)',
		attributionUrl:
			'https://commons.wikimedia.org/wiki/File:Chapel_of_St_Mary_Tory.jpg'
	},
	{
		title: 'Tithe Barn',
		duration: '15–18 mins',
		summary:
			'Built in the 1330s for Shaftesbury Abbey; among the finest medieval barns in England.',
		image:
			'https://commons.wikimedia.org/wiki/Special:FilePath/Tithe%20Barn%20at%20Bradford%20on%20Avon.JPG',
		imageAlt: 'Tithe Barn at Bradford-on-Avon',
		attributionLabel: 'Rodw / Rod Ward (Public Domain)',
		attributionUrl:
			'https://commons.wikimedia.org/wiki/File:Tithe_Barn_at_Bradford_on_Avon.JPG'
	},
	{
		title: 'Barton Farm Country Park',
		duration: '15–18 mins',
		summary:
			'Meadows, riverside paths, and the 14th-century packhorse bridge.',
		image:
			'https://commons.wikimedia.org/wiki/Special:FilePath/Barton%20Park%20Packhorse%20Bridge%20-%20geograph.org.uk%20-%20942621.jpg',
		imageAlt: 'Packhorse bridge at Barton Farm area, Bradford-on-Avon',
		attributionLabel: 'Betty Longbottom (CC BY-SA 2.0)',
		attributionUrl:
			'https://commons.wikimedia.org/wiki/File:Barton_Park_Packhorse_Bridge_-_geograph.org.uk_-_942621.jpg'
	},
	{
		title: 'Town Bridge & the Lock-Up',
		duration: '3–4 mins',
		summary:
			'13th–14th-century bridge foundations; lock-up added in the 17th century.',
		image:
			'https://commons.wikimedia.org/wiki/Special:FilePath/Bradford%20on%20Avon%20town%20bridge.jpg',
		imageAlt: 'Town bridge in Bradford-on-Avon',
		attributionLabel: 'Charles Miller (CC BY 2.0)',
		attributionUrl:
			'https://commons.wikimedia.org/wiki/File:Bradford_on_Avon_town_bridge.jpg'
	},
	{
		title: 'Iford Manor Gardens',
		duration: 'Arts and Culture',
		summary:
			'Italianate design, tranquil terraces, and one of the area\'s most atmospheric garden settings.',
		image:
			'https://commons.wikimedia.org/wiki/Special:FilePath/Iford%20manor%20gardens%2039.jpg',
		imageAlt: 'Iford Manor Gardens',
		attributionLabel: 'Scott Wylie (CC BY-SA 4.0)',
		attributionUrl:
			'https://commons.wikimedia.org/wiki/File:Iford_manor_gardens_39.jpg'
	}
];
---

<Layout title="Bradford-on-Avon History | The Stables" description="Historic highlights in and around Bradford-on-Avon.">
	<div class="page">
		<SiteNav currentPath={Astro.url.pathname} />
		<main>
			<header class="hero">
				<p class="eyebrow">Town Story</p>
				<h1>History Highlights</h1>
				<p>
					A practical list of key historic stops in and around Bradford-on-Avon, with quick walking times.
				</p>
				<div class="hero-meta">
					<p><span class="icon icon-route"></span>Chronological landmarks</p>
					<p><span class="icon icon-clock"></span>Short walk timings</p>
					<p><span class="icon icon-map"></span>Town + nearby highlights</p>
				</div>
			</header>

			<section class="history-grid" aria-label="Historic highlights">
				{historyStops.map((stop) => (
					<article class="history-card">
						<img src={stop.image} alt={stop.imageAlt} loading="lazy" />
						<div class="content">
							<h2>{stop.title}</h2>
							<p class="meta-row"><span class="icon icon-clock"></span><span class="duration">{stop.duration}</span></p>
							<p>{stop.summary}</p>
							<p class="credit">
								Photo:
								<a href={stop.attributionUrl} target="_blank" rel="noreferrer">{stop.attributionLabel}</a>
							</p>
						</div>
					</article>
				))}
			</section>
		</main>
	</div>
</Layout>

<style>
	.page {
		min-height: 100vh;
		padding: 2rem 1.25rem 3rem;
		background:
			radial-gradient(circle at 10% 0%, rgba(182, 132, 58, 0.16), transparent 36%),
			radial-gradient(circle at 100% 100%, rgba(42, 75, 57, 0.17), transparent 36%),
			#f5efe4;
	}

	main {
		max-width: 980px;
		margin: 0 auto;
	}

	.hero {
		padding-top: 0.7rem;
	}

	.eyebrow {
		margin: 0 0 0.4rem;
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #6e5d43;
	}

	h1 {
		font-family: 'Palatino Linotype', 'Book Antiqua', Palatino, serif;
		font-size: clamp(2rem, 4.8vw, 3.2rem);
		margin: 0;
	}

	.hero p {
		max-width: 64ch;
		margin: 0.7rem 0 0;
		color: #40362b;
	}

	.hero-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: 0.8rem;
	}

	.hero-meta p {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		margin: 0;
		font-size: 0.86rem;
		color: #5b4c39;
	}

	.history-grid {
		margin-top: 1.3rem;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1rem;
	}

	.history-card {
		background: rgba(255, 255, 255, 0.78);
		border: 1px solid rgba(96, 74, 43, 0.2);
		border-radius: 14px;
		overflow: hidden;
	}

	.history-card img {
		width: 100%;
		height: 170px;
		object-fit: cover;
		display: block;
	}

	.content {
		padding: 0.9rem;
	}

	.content h2 {
		margin: 0;
		font-size: 1.15rem;
		font-family: 'Palatino Linotype', 'Book Antiqua', Palatino, serif;
	}

	.meta-row {
		display: inline-flex;
		align-items: center;
		gap: 0.42rem;
		margin: 0.55rem 0 0;
	}

	.duration {
		display: inline-block;
		padding: 0.18rem 0.5rem;
		border-radius: 999px;
		font-size: 0.78rem;
		font-weight: 600;
		background: #ebe0cc;
		color: #5b4728;
	}

	.icon {
		display: inline-block;
		width: 0.62rem;
		height: 0.62rem;
		border-radius: 999px;
		background: #78613f;
		flex: none;
	}

	.icon-clock {
		background: #5f7c67;
	}

	.icon-map {
		background: #7d5a78;
	}

	.content p {
		margin: 0.65rem 0 0;
		color: #3f3429;
	}

	.credit {
		font-size: 0.86rem;
	}

	.credit a {
		color: #2f4b39;
		text-decoration: none;
		font-weight: 600;
	}

	.credit a:hover {
		text-decoration: underline;
	}
</style>
