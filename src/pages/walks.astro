---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';

const walks = [
	{
		title: 'Canal Towpath to Avoncliff',
		duration: '45–55 mins one way',
		summary:
			'Flat, scenic canal walk ending at the Cross Guns beside the river; includes the Avoncliff Aqueduct (1805).',
		image:
			'https://commons.wikimedia.org/wiki/Special:FilePath/Avoncliff%20Aqueduct%20-%20geograph.org.uk%20-%204250386.jpg',
		imageAlt: 'Avoncliff Aqueduct on the Kennet and Avon Canal',
		attributionLabel: 'Derek Harper (CC BY-SA 2.0)',
		attributionUrl:
			'https://commons.wikimedia.org/wiki/File:Avoncliff_Aqueduct_-_geograph.org.uk_-_4250386.jpg'
	},
	{
		title: 'Barton Farm Loop',
		duration: '25–30 mins',
		summary:
			'Meadows, riverside paths, the packhorse bridge, and the Tithe Barn.',
		image:
			'https://commons.wikimedia.org/wiki/Special:FilePath/Barton%20Park%20Packhorse%20Bridge%20-%20geograph.org.uk%20-%20942621.jpg',
		imageAlt: 'Barton Park Packhorse Bridge near Bradford-on-Avon',
		attributionLabel: 'Betty Longbottom (CC BY-SA 2.0)',
		attributionUrl:
			'https://commons.wikimedia.org/wiki/File:Barton_Park_Packhorse_Bridge_-_geograph.org.uk_-_942621.jpg'
	},
	{
		title: 'The Ridge / Tory Hill Viewpoint',
		duration: '25–35 mins',
		summary:
			'Steady climb to the best panoramic view of Bradford-on-Avon (steep in places).',
		image:
			'https://commons.wikimedia.org/wiki/Special:FilePath/Bradford-on-Avon%20panorama,%20Wiltshire,%20UK%20-%20Diliff.jpg',
		imageAlt: 'Panoramic view over Bradford-on-Avon',
		attributionLabel: 'DAVID ILIFF / Diliff (CC BY-SA 3.0)',
		attributionUrl:
			'https://commons.wikimedia.org/wiki/File:Bradford-on-Avon_panorama,_Wiltshire,_UK_-_Diliff.jpg'
	},
	{
		title: 'Iford Valley & Farleigh Hungerford',
		duration: '1.5–2 hrs circular',
		summary:
			'Classic countryside circuit with Farleigh Hungerford Castle (c.1370).',
		image:
			'https://commons.wikimedia.org/wiki/Special:FilePath/Farleigh%20Hungerford%20Castle%202015%2046.jpg',
		imageAlt: 'Farleigh Hungerford Castle exterior',
		attributionLabel: 'Mike Peel (CC BY-SA 4.0)',
		attributionUrl:
			'https://commons.wikimedia.org/wiki/File:Farleigh_Hungerford_Castle_2015_46.jpg'
	}
];
---

<Layout title="Local Walks in Bradford-on-Avon | The Stables" description="Scenic Bradford-on-Avon walking routes with timings, highlights, and landmarks.">
	<div class="page">
		<SiteNav currentPath={Astro.url.pathname} />
		<main>
			<header class="hero">
				<p class="eyebrow">History & Landscape</p>
				<h1>Local Walks</h1>
				<p>
					Four classic Bradford-on-Avon routes, from quick riverside loops to longer countryside circuits.
				</p>
				<div class="hero-meta">
					<p><span class="icon icon-route"></span>Route-led planning</p>
					<p><span class="icon icon-clock"></span>Practical timings</p>
					<p><span class="icon icon-map"></span>Best local scenery</p>
				</div>
			</header>

			<section class="walk-grid" aria-label="Local walk routes">
				{walks.map((walk) => (
					<article class="walk-card">
						<img src={walk.image} alt={walk.imageAlt} loading="lazy" />
						<div class="content">
							<h2>{walk.title}</h2>
							<p class="meta-row"><span class="icon icon-clock"></span><span class="duration">{walk.duration}</span></p>
							<p>{walk.summary}</p>
							<p class="credit">
								Photo:
								<a href={walk.attributionUrl} target="_blank" rel="noreferrer">{walk.attributionLabel}</a>
							</p>
						</div>
					</article>
				))}
			</section>
		</main>
	</div>
</Layout>

<style>
	.page {
		min-height: 100vh;
		padding: 2rem 1.25rem 3rem;
		background:
			radial-gradient(circle at 8% 0%, rgba(182, 132, 58, 0.16), transparent 36%),
			radial-gradient(circle at 92% 100%, rgba(42, 75, 57, 0.18), transparent 40%);
	}

	main {
		max-width: 980px;
		margin: 0 auto;
	}

	.hero {
		padding-top: 0.7rem;
	}

	.eyebrow {
		margin: 0 0 0.4rem;
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #6e5d43;
	}

	h1 {
		font-family: 'Palatino Linotype', 'Book Antiqua', Palatino, serif;
		font-size: clamp(2rem, 4.8vw, 3.2rem);
		margin: 0;
	}

	.hero p {
		max-width: 64ch;
		margin: 0.7rem 0 0;
		color: #40362b;
	}

	.hero-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: 0.8rem;
	}

	.hero-meta p {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		margin: 0;
		font-size: 0.86rem;
		color: #5b4c39;
	}

	.walk-grid {
		margin-top: 1.3rem;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1rem;
	}

	.walk-card {
		background: rgba(255, 255, 255, 0.78);
		border: 1px solid rgba(96, 74, 43, 0.2);
		border-radius: 14px;
		overflow: hidden;
	}

	.walk-card img {
		width: 100%;
		height: 170px;
		object-fit: cover;
		display: block;
	}

	.content {
		padding: 0.9rem;
	}

	.content h2 {
		margin: 0;
		font-size: 1.15rem;
		font-family: 'Palatino Linotype', 'Book Antiqua', Palatino, serif;
	}

	.meta-row {
		display: inline-flex;
		align-items: center;
		gap: 0.42rem;
		margin: 0.55rem 0 0;
	}

	.duration {
		display: inline-block;
		padding: 0.18rem 0.5rem;
		border-radius: 999px;
		font-size: 0.78rem;
		font-weight: 600;
		background: #ebe0cc;
		color: #5b4728;
	}

	.icon {
		display: inline-block;
		width: 0.62rem;
		height: 0.62rem;
		border-radius: 999px;
		background: #78613f;
		flex: none;
	}

	.icon-clock {
		background: #5f7c67;
	}

	.icon-map {
		background: #7d5a78;
	}

	.content p {
		margin: 0.65rem 0 0;
		color: #3f3429;
	}

	.credit {
		font-size: 0.86rem;
	}

	.credit a {
		color: #2f4b39;
		text-decoration: none;
		font-weight: 600;
	}

	.credit a:hover {
		text-decoration: underline;
	}
</style>
